<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta http-equiv="refresh" content="60">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>IBM MQ / ACE Platform Status</title>
  <style>
    body { font-family: -apple-system, Segoe UI, Arial, sans-serif; margin: 2rem; background: #f4f6f8; color: #222; }
    h1 { margin: 0 0 .2rem; }
    .ts { color: #666; margin-bottom: 1.5rem; font-size: .9rem; }
    .cards {
      display: grid;
      grid-template-columns: 1.05fr 1fr 1fr;
      grid-template-areas:
        "ansible server1 server1"
        "ansible server2 server3";
      gap: 1.5rem;
      align-items: start;
      max-width: 1600px;
    }
    /* Narrow screens: stack everything in one column. */
    @media (max-width: 1100px) {
      .cards { grid-template-columns: 1fr; grid-template-areas: "ansible" "server1" "server2" "server3"; }
    }
    .card { background: #fff; box-shadow: 0 1px 4px rgba(0,0,0,.12); border-radius: 6px; overflow: hidden; }
    .card h2 { margin: 0; padding: .7rem 1rem; background: #2d3e50; color: #fff; font-size: 1.05rem; }
    .card h2 small { font-weight: 400; opacity: .8; }
    table { border-collapse: collapse; width: 100%; }
    th, td { padding: .5rem 1rem; border-bottom: 1px solid #eee; text-align: left; font-size: .92rem; overflow-wrap: anywhere; }
    th { background: #eef1f4; font-size: .78rem; text-transform: uppercase; letter-spacing: .03em; }
    .sec { padding: .45rem 1rem; background: #f7f9fb; font-weight: 700; font-size: .8rem; text-transform: uppercase; color: #557; }
    .badge { font-weight: 700; border-radius: 4px; padding: .12rem .55rem; font-size: .82rem; }
    .PASS { background: #1e8e3e; color: #fff; }
    .FAIL { background: #d23f31; color: #fff; }
    a.link { color: #1558d6; text-decoration: none; }
    a.link:hover { text-decoration: underline; }
    .muted { color: #999; }
    .legend { margin-top: 1.5rem; font-size: .85rem; color: #666; }
  </style>
</head>
<body>
  <h1>IBM MQ / ACE Platform Status</h1>
  <div class="ts">Last updated: {{ ansible_date_time.iso8601 }} &nbsp;·&nbsp; auto-refresh every 60s</div>
  <div class="cards">
    <div class="card" style="grid-area: ansible;">
      <h2>Ansible Control Node <small>{% if ctl_public_ip | default('') %}· {{ ctl_public_ip }}{% endif %}</small></h2>
      <table>
        <tr><th>Item</th><th>Detail</th></tr>

        <tr class="sec"><td colspan="2">Server details</td></tr>
        <tr><td>Hostname</td><td>{{ ctl_hostname | default('—') }}</td></tr>
        <tr><td>Public IP</td><td>{{ ctl_public_ip | default('') or '—' }}</td></tr>
        <tr><td>Private IP</td><td>{{ ctl_private_ip | default('') or '—' }}</td></tr>
        <tr><td>OS</td><td>{{ ctl_os | default('') | trim or '—' }}</td></tr>
        <tr><td>Ansible</td><td>{{ ctl_ansible_ver | default('') or '—' }}</td></tr>

        <tr class="sec"><td colspan="2">Playbooks</td></tr>
        <tr><td>Playbook location</td><td><code>{{ ctl_playbook_dir | default('/etc/ansible/playbooks') }}</code></td></tr>
        <tr><td>Dump playbooks</td><td><code>/opt/apps/mqaceserver/playbooks</code></td></tr>

        <tr class="sec"><td colspan="2">Cron jobs &amp; last run</td></tr>
        {% for c in ctl_cron_lines | default([]) %}
          {% set parts = c.split('|') %}
          <tr>
            <td>{{ parts[0] }}<br><span class="muted">schedule: <code>{{ parts[1] | default('') }}</code></span></td>
            <td><span class="badge {{ 'FAIL' if (parts[2] | default('never') == 'never') else 'PASS' }}">{{ 'last run: ' ~ parts[2] if (parts[2] | default('never') != 'never') else 'never run' }}</span></td>
          </tr>
        {% else %}
          <tr><td colspan="2" class="muted">No cron jobs found</td></tr>
        {% endfor %}

        <tr class="sec"><td colspan="2">MQ+ACE MCP stack</td></tr>
        {% for e in mqacemcp_endpoints | default([]) %}
          {% set p = e.split('|') %}
          {% set url = p[1] ~ '://' ~ (ctl_public_ip | default('localhost')) ~ ':' ~ p[2] ~ p[3] %}
          <tr>
            <td>{{ p[0] }}<br><span class="muted"><a class="link" href="{{ url }}" target="_blank">{{ url }}</a></span></td>
            <td><span class="badge {{ 'PASS' if (p[4] == 'UP') else 'FAIL' }}">{{ p[4] }}{% if p[5] | default('') and p[5] != '200' %} ({{ p[5] }}){% endif %}</span></td>
          </tr>
        {% else %}
          <tr><td colspan="2" class="muted">MCP stack not detected</td></tr>
        {% endfor %}

        <tr class="sec"><td colspan="2">Secure access (Caddy gateway · HTTPS + login)</td></tr>
        {% for e in gateway_endpoints | default([]) %}
          {% set p = e.split('|') %}
          {% set url = 'https://' ~ (ctl_public_ip | default('localhost')) ~ ':' ~ p[1] ~ p[2] %}
          <tr>
            <td>{{ p[0] }}<br><span class="muted"><a class="link" href="{{ url }}" target="_blank">{{ url }}</a> · Basic Auth (user: admin)</span></td>
            <td><span class="badge {{ 'PASS' if (p[3] == 'UP') else 'FAIL' }}">{{ p[3] }}{% if p[4] | default('') and p[4] not in ['200', '401'] %} ({{ p[4] }}){% endif %}</span></td>
          </tr>
        {% else %}
          <tr><td colspan="2" class="muted">Gateway not detected</td></tr>
        {% endfor %}

        <tr class="sec"><td colspan="2">Config dump downloads</td></tr>
        {% for c in ctl_csv_files | default([]) %}
          {% set f = c.split('|') %}
          <tr>
            <td>{{ f[0] }}<br><span class="muted">{{ f[1] | default('') }} · updated {{ f[2] | default('') }}</span></td>
            <td><a class="link" href="{{ f[0] }}" download>download</a></td>
          </tr>
        {% else %}
          <tr><td colspan="2" class="muted">No dump CSVs yet (run every 30 min)</td></tr>
        {% endfor %}

        <tr class="sec"><td colspan="2">Documentation &amp; references</td></tr>
        {% if ctl_doc_files | default([]) %}
          {% for d in ctl_doc_files %}
            {% set df = d.split('|') %}
            <tr>
              <td>{{ df[1] | default(df[0]) }}<br><span class="muted">{{ df[2] | default('') }}</span></td>
              <td><a class="link" href="{{ df[0] }}" target="_blank">open</a></td>
            </tr>
          {% endfor %}
        {% else %}
          <tr><td colspan="2" class="muted">No reference docs published</td></tr>
        {% endif %}
      </table>
    </div>
  {% for host in groups['all_mq_servers'] | sort %}
  {% set hv = hostvars[host] %}
  {% set pub = hv.public_ip | default('') %}
  {% set ace = hv.is_ace | default(false) | bool %}
    <div class="card" style="grid-area: {{ host }};">
      <h2>{{ host }} <small>— {{ 'MQ + ACE' if ace else 'MQ' }}{% if pub %} · {{ pub }}{% endif %}</small></h2>
      <table>
        <tr><th>Item</th><th>Status</th></tr>

        <tr class="sec"><td colspan="2">IBM MQ</td></tr>
        <tr>
          <td>MQ installation</td>
          <td>{% if hv.mq_installed | default(false) | bool %}<span class="badge PASS">{{ hv.mq_version }}</span>{% else %}<span class="badge FAIL">Not installed</span>{% endif %}</td>
        </tr>

        <tr class="sec"><td colspan="2">Queue Managers</td></tr>
        {% if hv.qmgr_lines | default([]) | length > 0 %}
          {% for line in hv.qmgr_lines %}
          {% set qm = line.split('|') %}
          <tr>
            <td>{{ qm[0] }}</td>
            <td><span class="badge {{ 'PASS' if (qm[1] | default('') == 'Running') else 'FAIL' }}">{{ qm[1] | default('Unknown') }}</span></td>
          </tr>
          {% endfor %}
        {% else %}
          <tr><td colspan="2" class="muted">No queue managers found</td></tr>
        {% endif %}

        <tr class="sec"><td colspan="2">MQ Web Console</td></tr>
        <tr>
          <td>mqweb</td>
          <td><span class="badge {{ 'PASS' if (hv.mq_web_ok | default(false) | bool) else 'FAIL' }}">{{ 'Running' if (hv.mq_web_ok | default(false) | bool) else 'Down' }}</span></td>
        </tr>
        {% if pub %}
        <tr>
          <td>Console link</td>
          <td><a class="link" href="https://{{ pub }}:{{ mq_web_port }}/ibmmq/console/" target="_blank">https://{{ pub }}:{{ mq_web_port }}/ibmmq/console/</a></td>
        </tr>
        {% endif %}

        {% if ace %}
        <tr class="sec"><td colspan="2">IBM ACE</td></tr>
        <tr>
          <td>ACE installation</td>
          <td>{% if hv.ace_installed | default(false) | bool %}<span class="badge PASS">{{ hv.ace_version_str | default('Installed', true) or 'Installed' }}</span>{% else %}<span class="badge FAIL">Not installed</span>{% endif %}</td>
        </tr>
        <tr>
          <td>ACE node ({{ hv.ace_node_name | default('') }})</td>
          <td><span class="badge {{ 'PASS' if (hv.ace_node_ok | default(false) | bool) else 'FAIL' }}">{{ 'Active' if (hv.ace_node_ok | default(false) | bool) else 'Down' }}</span></td>
        </tr>
        <tr>
          <td>ACE Web UI</td>
          <td><span class="badge {{ 'PASS' if (hv.ace_web_ok | default(false) | bool) else 'FAIL' }}">{{ 'Up' if (hv.ace_web_ok | default(false) | bool) else 'Down' }}</span></td>
        </tr>
        {% if pub %}
        <tr>
          <td>ACE Web link</td>
          <td><a class="link" href="https://{{ pub }}:{{ hv.ace_web_port | default(4414) }}/" target="_blank">https://{{ pub }}:{{ hv.ace_web_port | default(4414) }}/</a></td>
        </tr>
        {% endif %}
        {% endif %}
      </table>
    </div>
  {% endfor %}
  </div>
  <div class="legend">Generated by <code>validate_platform.yml</code> — runs every 2 minutes via cron on the Ansible control node.</div>
</body>
</html>
